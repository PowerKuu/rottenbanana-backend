// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum Role {
  USER
  ADMIN
}

// ── AUTH MODELS — DO NOT MODIFY ────────────────────────────────────────────
// Managed by better-auth. Only domain back-reference fields added to User.
model User {
  id            String  @id
  name          String
  email         String
  emailVerified Boolean @default(false)
  image         String?
  role          Role   @default(USER)

  sessions       Session[]
  accounts       Account[]
  tryOnOutfits   TryOnOutfit[]
  postLikes      PostLike[]
  preferenceTags UserPreferenceTag[]

  gender                        Gender?
  referenceImageId             String?
  aiNormalizedReferenceImageId String?
  onboardingCompleted            Boolean @default(false)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PreferenceTag {
  id  String @id @default(cuid())
  tag String @unique
  description String

  userPreferenceTags    UserPreferenceTag[]
  postPreferenceTags    PostPreferenceTag[]
  productPreferenceTags ProductPreferenceTag[]
  musicPreferenceTags   MusicPreferenceTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id   String @id @default(cuid())
  name String @unique

  posts  Post[]
  stores Store[]
  users  User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model File {
  id        String   @id @default(cuid())
  name     String
  type      String

  privateUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id         String @id @default(cuid())
  scraperIdentifier String

  name       String
  websiteUrl String
  websiteHostnames String[]

  imageId   String

  products        Product[]
  pendingProducts PendingProduct[]
  regions         Region[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

enum ProductSlot {
  UPPERBODY_LAYER_1
  UPPERBODY_LAYER_2
  UPPERBODY_LAYER_3
  LOWERBODY_LAYER_1
  FOOTWEAR_LAYER_1
  FOOTWEAR_LAYER_2

  GLASSES
  BAG
  MASK
  BELT
  HAT
  GLOVES
  SCARF
  WATCH
  BRACELETS
  EARRINGS
  TIE
  RING
  OTHER
}

enum ProductCategory {
  TSHIRTS_TOPS
  POLOS
  SHIRTS
  BLOUSES
  TANK_TOPS
  CROP_TOPS
  SWEATSHIRTS
  HOODIES
  JACKETS
  BLAZERS
  COATS
  PARKAS
  VESTS
  TROUSERS
  JEANS
  SHORTS
  SKIRTS
  LEGGINGS
  DRESSES
  JUMPSUITS_ROMPERS
  SPORTSWEAR
  SOCKS
  SNEAKERS
  BOOTS
  SANDALS_FLIPFLOPS
  DRESS_SHOES
  ATHLETIC_SHOES
  SLIPPERS
  BAGS
  BELTS
  HATS_CAPS
  SCARVES_WRAPS
  GLOVES_MITTENS
  JEWELRY
  WATCHES
  SUNGLASSES
  EYEGLASSES
  TIES_BOWTIES
  PERFUMES_COLOGNES
  OTHER
}

enum PendingProductStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

model PendingProduct {
  id              String   @id @default(cuid())
  url             String   @unique
  imageUrl      String
  status          PendingProductStatus @default(PENDING)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  priceGross     Float
  originalPriceGross Float?

  currency        String
  productOnlyImageId String
  imageIds       String[]

  description String?
  brand       String?
  metadata    Json
  url         String @unique
  slot        ProductSlot
  category       ProductCategory

  primaryColorCIELAB Float[]
  primaryColorHex    String

  storeId          String
  store            Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  tryOnOutfitItems TryOnOutfitProduct[]
  postProducts     PostProduct[]
  preferenceTags   ProductPreferenceTag[]

  gender Gender

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model TryOnOutfit {
  id                String   @id @default(cuid())
  referenceImageId String
  resultImageIds   String[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  products TryOnOutfitProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TryOnOutfitProduct {
  tryOnOutfitId String
  productId     String

  tryOnOutfit TryOnOutfit @relation(fields: [tryOnOutfitId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([tryOnOutfitId, productId])
  @@index([productId])
  @@index([tryOnOutfitId])
}

model PostProduct {
  productId String
  postId    String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([productId, postId])
  @@index([postId])
  @@index([productId])
}

model Music {
  id        String   @id @default(cuid())
  name      String
  musicId   String
  description String
  posts          Post[]
  preferenceTags MusicPreferenceTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Post {
  id        String   @id @default(cuid())
  caption   String?
  imageIds String[]


  likes PostLike[]
  preferenceTags PostPreferenceTag[]
  products PostProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Restrict)

  musicId String
  music   Music @relation(fields: [musicId], references: [id], onDelete: Restrict)

  isOfficial Boolean @default(false)
}

model PostLike {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
}

model UserPreferenceTag {
  score Int @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferenceTagId String
  preferenceTag   PreferenceTag @relation(fields: [preferenceTagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, preferenceTagId])
  @@index([preferenceTagId])
  @@index([userId, score(sort: Desc)])
}

model PostPreferenceTag {
  postId String
  post  Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  preferenceTagId String
  preferenceTag   PreferenceTag @relation(fields: [preferenceTagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([postId, preferenceTagId])
  @@index([preferenceTagId])
}

model ProductPreferenceTag {
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  preferenceTagId String
  preferenceTag   PreferenceTag @relation(fields: [preferenceTagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([productId, preferenceTagId])
  @@index([preferenceTagId])
}

model MusicPreferenceTag {
  musicId String
  music   Music @relation(fields: [musicId], references: [id], onDelete: Cascade)

  preferenceTagId String
  preferenceTag   PreferenceTag @relation(fields: [preferenceTagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([musicId, preferenceTagId])
  @@index([preferenceTagId])
}
