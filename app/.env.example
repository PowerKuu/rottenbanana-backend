# Database — matches docker-compose.yml
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Better Auth
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Email — Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM=""

# AI APIs
AI_GATEWAY_API_KEY=""  # AI Vercel Gateway
GOOGLE_API_KEY=""  # Google Generative AI (https://aistudio.google.com)

BASE_URL=""

# Apple Sign In
APPLE_CLIENT_ID=""                                # Service ID, e.g. ai.plagg.plagg.signin
APPLE_CLIENT_SECRET=""                            # Generated JWT (see generate-apple-secret.ts), valid 6 months
APPLE_APP_BUNDLE_IDENTIFIER="ai.plagg.plagg"      # Used for native iOS token validation

# Google Sign In
GOOGLE_AUTH_CLIENT_ID=""                           # Web application OAuth client ID
GOOGLE_AUTH_CLIENT_SECRET=""                       # Web application OAuth client secret
